{
  "name": "@coe/tokens",
  "version": "0.1.0",
  "description": "UF COE design tokens — colors, typography, spacing, and more",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./json": "./dist/tokens.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs && node scripts/build-json.mjs",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "sideEffects": false
}
